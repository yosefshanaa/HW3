# ---------------------------------------------------------------------------
# Secret placeholders. Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and MUST NEVER be committed (submission guidelines §7.4).
# ---------------------------------------------------------------------------

# OpenAI API key used by the CrewAI agents (required to run content generation).
OPENAI_API_KEY=your_api_key_here

# Optional: override the OpenAI-compatible base URL (e.g. for a proxy / Azure).
OPENAI_BASE_URL=

# Optional: model the crew should use. Defaults to value in config/setup.json.
OPENAI_MODEL=
