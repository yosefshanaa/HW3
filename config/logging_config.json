{
  "version": 1,
  "disable_existing_loggers": false,
  "filters": {
    "redaction": {
      "()": "startup_book.shared.redaction.RedactionFilter"
    }
  },
  "formatters": {
    "jsonline": {
      "()": "startup_book.shared.logging_setup.JsonLineFormatter"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "jsonline",
      "filters": ["redaction"],
      "stream": "ext://sys.stderr"
    }
  },
  "loggers": {
    "startup_book": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    }
  },
  "root": {
    "level": "WARNING",
    "handlers": ["console"]
  }
}
